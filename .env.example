TELEGRAM_BOT_TOKEN=
# Кому разрешён бот и кому слать отчёты (числовые user id через запятую).
# Узнать свой id: напиши боту @userinfobot или посмотри в логах после /start.
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
# Устаревший вариант для одного человека (то же что user id в личке):
# TELEGRAM_CHAT_ID=123456789

TIMEZONE=Europe/Moscow

# Путь к .env бэкенда: оттуда подтягиваются GPT_API_KEY, ChatGPT_API_KEY, SUNO_API_KEY и т.д.
BACKEND_ENV_FILE=../keepai_backend/.env

CLAUDE_MODEL=claude-3-5-haiku-latest
# Самая дешёвая стабильная текстовая модель в семействе 2.5 (см. ai.google.dev/gemini-api/docs/models).
GEMINI_MODEL=gemini-2.5-flash-lite
PERPLEXITY_MODEL=sonar
GROK_MODEL=grok-2-latest

BALANCE_ALERT_USD=5.0
BALANCE_ALERT_TOKENS=1000
REPORT_HOUR=8
